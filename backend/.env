DATABASE_URL="postgresql://postgres:password@localhost:5432/manzil_db"
PORT=5000
NODE_ENV=development
JWT_ACCESS_SECRET=manzil-access-secret-key-change-in-production-32chars
JWT_REFRESH_SECRET=manzil-refresh-secret-key-change-in-production-32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=manzil-cookie-secret-key-change-in-production-32ch
CLIENT_URL=http://localhost:5173
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
