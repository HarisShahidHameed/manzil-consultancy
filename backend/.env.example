# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/manzil_db"

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie
COOKIE_SECRET=your-cookie-secret-min-32-chars-here

# CORS
CLIENT_URL=http://localhost:5173

# Account lockout
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Seed — only used by `prisma/seed.ts`. In production, set a real email and a
# strong password here so the seeded admin account isn't the published default.
# Change the password via the app immediately after first login.
SEED_ADMIN_EMAIL=admin@manzil.com
SEED_ADMIN_PASSWORD=change-me-before-first-deploy
